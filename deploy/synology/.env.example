# 必填：PostgreSQL 密码。建议至少 32 个随机字符。
DATABASE_PASSWORD=请替换为随机数据库密码

# 必填：Base64 编码的 32 字节随机密钥。部署后请妥善备份，不要随意修改。
DATA_ENCRYPTION_KEY=请替换为Base64编码的32字节密钥

# 必填：首次创建管理员时使用的一次性口令。建议至少 32 个随机字符。
ADMIN_SETUP_TOKEN=请替换为随机管理员初始化口令

# 可选：允许访问 API 的 Host，多个值用分号分隔。域名尚未确定时可暂用 *。
ALLOWED_HOSTS=*

# 可选：Cloudflare Tunnel 或 NAS 反向代理所在的 Docker 私网。
FORWARDED_NETWORK=172.16.0.0/12

# 仅在启用 nas-port profile 时使用。默认只监听群晖本机回环地址，不对局域网或公网开放。
MT_API_BIND_ADDRESS=127.0.0.1
MT_API_BIND_PORT=8888

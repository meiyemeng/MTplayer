<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="1080dp"
    android:layout_height="620dp"
    android:layout_gravity="center"
    android:background="@drawable/mtplayer_app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="38dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:gravity="center_vertical" android:orientation="horizontal">
            <ImageView android:layout_width="76dp" android:layout_height="76dp" android:contentDescription="MT播放器" android:src="@drawable/mtplayer_launcher" />
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="20dp" android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="关于 MT播放器" android:textColor="#FFFF7B6E" android:textSize="34sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:text="感谢您的支持，让 MT播放器持续进步" android:textColor="#FFAAB5C6" android:textSize="16sp" />
            </LinearLayout>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="当前版本  1.3.3" android:textColor="#FFFF7B6E" android:textSize="16sp" />
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="380dp" android:layout_marginTop="24dp" android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1.35" android:background="@drawable/mtplayer_glow_panel" android:orientation="vertical" android:padding="26dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:text="●  开源地址" android:textColor="#FFFF7B6E" android:textSize="20sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:text="github.com/meiyemeng/MTplayer" android:textColor="#FFC7D0DE" android:textSize="16sp" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="22dp" android:text="✉  联系邮箱" android:textColor="#FFFF7B6E" android:textSize="20sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="7dp" android:text="m@salego.cn" android:textColor="#FFC7D0DE" android:textSize="16sp" />
                <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginTop="22dp" android:background="#39455A" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="法律声明" android:textColor="#FFFFF7F5" android:textSize="20sp" android:textStyle="bold" />
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:lineSpacingExtra="5dp" android:text="MT播放器仅作为本地媒体播放工具，不提供、上传、存储或分发任何内容，也不内置或聚合任何第三方资源。用户所播放的内容均来自本地文件或其合法拥有的来源，请遵守所在地法律法规。\n\n本软件基于 TVBoxOS（AGPL-3.0）修改发布。" android:textColor="#FFAAB5C6" android:textSize="15sp" />
            </LinearLayout>

            <LinearLayout android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="22dp" android:layout_weight="1" android:background="@drawable/mtplayer_action_card" android:gravity="center_horizontal" android:orientation="vertical" android:padding="22dp">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="♡  支持开发者" android:textColor="#FFFF7B6E" android:textSize="24sp" android:textStyle="bold" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="6dp" android:gravity="center" android:text="如果 MT播放器对您有帮助，欢迎通过支付宝打赏支持" android:textColor="#FFC7D0DE" android:textSize="14sp" />
                <ImageView android:layout_width="220dp" android:layout_height="220dp" android:layout_marginTop="14dp" android:background="@drawable/mtplayer_outline_button" android:contentDescription="支付宝捐助收款码" android:padding="10dp" android:src="@drawable/alipay_donate" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:text="支付宝 · 打开支付宝扫一扫" android:textColor="#FFFF7B6E" android:textSize="15sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="66dp" android:layout_marginTop="18dp" android:orientation="horizontal">
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:background="@drawable/mtplayer_action_card" android:gravity="center" android:text="▣  TVBoxOS 基础" android:textColor="#FFFFF7F5" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="14dp" android:layout_weight="1" android:background="@drawable/mtplayer_action_card" android:gravity="center" android:text="□  本地优先" android:textColor="#FFFFF7F5" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:layout_width="0dp" android:layout_height="match_parent" android:layout_marginStart="14dp" android:layout_weight="1" android:background="@drawable/mtplayer_action_card" android:gravity="center" android:text="☁  跨端同步" android:textColor="#FFFFF7F5" android:textSize="16sp" android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="700dp"
    android:layout_height="wrap_content"
    android:layout_gravity="center"
    android:background="@drawable/shape_dialog_bg_main">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/vs_30">

        <ImageView
            android:layout_width="@dimen/vs_140"
            android:layout_height="@dimen/vs_140"
            android:layout_gravity="center_horizontal"
            android:contentDescription="MT播放器"
            android:src="@drawable/mtplayer_launcher" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/vs_12"
            android:gravity="center"
            android:text="MT播放器"
            android:textColor="@color/color_CC000000"
            android:textSize="@dimen/ts_30"
            android:textStyle="bold" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:lineSpacingExtra="18sp"
            android:text="MT播放器仅提供播放器与配置解析能力，不预置、不存储、不上传、不分发任何影视内容。所有内容均由用户自行配置，并确保拥有合法访问权。\n\n源码仓库：https://github.com/meiyemeng/MTplayer\n联系邮箱：m@salego.cn\n\n如本项目对你有帮助，欢迎扫码支持维护。"
            android:textColor="@color/color_CC000000"
            android:textSize="@dimen/ts_22" />
        <ImageView
            android:layout_width="@dimen/vs_300"
            android:layout_height="@dimen/vs_300"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="18dp"
            android:contentDescription="支付宝捐助收款码"
            android:src="@drawable/alipay_donate" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="基于 TVBoxOS（AGPL-3.0）修改发布\n版本：1.3.3"
            android:textColor="@color/color_CC000000"
            android:textSize="@dimen/ts_20" />
    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle"><solid android:color="#FFD65A4D" /><corners android:radius="12dp" /></shape>
    </item>
    <item android:state_focused="true">
        <shape android:shape="rectangle"><solid android:color="#FFFF7565" /><corners android:radius="12dp" /><stroke android:width="2dp" android:color="#FFFFD3C9" /></shape>
    </item>
    <item>
        <shape android:shape="rectangle"><solid android:color="#FFF05D50" /><corners android:radius="12dp" /></shape>
    </item>
</selector>

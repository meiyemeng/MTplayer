<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <gradient android:angle="0" android:startColor="#6B282D" android:endColor="#241526" />
            <stroke android:width="2dp" android:color="#FF6B5F" />
            <corners android:radius="18dp" />
            <padding android:left="12dp" android:top="12dp" android:right="12dp" android:bottom="12dp" />
        </shape>
    </item>
    <item>
        <shape>
            <gradient android:angle="0" android:startColor="#1A263B" android:endColor="#10192A" />
            <stroke android:width="1dp" android:color="#3A475F" />
            <corners android:radius="18dp" />
            <padding android:left="12dp" android:top="12dp" android:right="12dp" android:bottom="12dp" />
        </shape>
    </item>
</selector>

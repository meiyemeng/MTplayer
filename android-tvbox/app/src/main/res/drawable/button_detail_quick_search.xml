<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_focused="true">
        <shape>
            <corners android:radius="@dimen/vs_20" />
            <gradient android:angle="0" android:startColor="#713036" android:endColor="#2B1827" />
            <stroke android:width="2dp" android:color="#FF6B5F" />
        </shape>
    </item>
    <item android:state_focused="false">
        <shape>
            <corners android:radius="@dimen/vs_20" />
            <solid android:color="#D91A2639" />
            <stroke android:width="1dp" android:color="#3D4B63" />
        </shape>
    </item>
</selector>

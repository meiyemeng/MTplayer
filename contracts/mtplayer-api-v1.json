  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      }
    },
    "schemas": {
      "SyncEntityKind": {
        "type": "string",
        "enum": [
          "ConfigurationGroup",
          "Favorite",
          "PlaybackHistory",
          "SkipMarker",
          "Preference"
        ]
      },
      "RegisterRequest": {
        "type": "object",
        "required": [
          "email",
          "password"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "LoginRequest": {
        "type": "object",
        "required": [
          "email",
          "password",
          "deviceName",
          "platform"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          },
          "password": {
            "type": "string"
          },
          "deviceName": {
            "type": "string"
          },
          "platform": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "RefreshRequest": {
        "type": "object",
        "required": [
          "refreshToken"
        ],
        "properties": {
          "refreshToken": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "VerifyEmailRequest": {
        "type": "object",
        "required": [
          "token"
        ],
        "properties": {
          "token": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "ForgotPasswordRequest": {
        "type": "object",
        "required": [
          "email"
        ],
        "properties": {
          "email": {
            "type": "string",
            "format": "email"
          }
        },
        "additionalProperties": false
      },
      "ResetPasswordRequest": {
        "type": "object",
        "required": [
          "token",
          "password"
        ],
        "properties": {
          "token": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TvTokenRequest": {
        "type": "object",
        "required": [
          "deviceCode"
        ],
        "properties": {
          "deviceCode": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TvApprovalRequest": {
        "type": "object",
        "required": [
          "userCode"
        ],
        "properties": {
          "userCode": {
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "TokenResponse": {
        "type": "object",
        "required": [
          "accessToken",
          "refreshToken",
          "expiresAtUtc",
          "emailVerified"
        ],
        "properties": {
          "accessToken": {
            "type": "string"
          },
          "refreshToken": {
            "type": "string"
          },
          "expiresAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "emailVerified": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      },
      "DeviceCodeResponse": {
        "type": "object",
        "required": [
          "deviceCode",
          "userCode",
          "verificationUri",
          "expiresAtUtc",
          "pollIntervalSeconds"
        ],
        "properties": {
          "deviceCode": {
            "type": "string"
          },
          "userCode": {
            "type": "string"
          },
          "verificationUri": {
            "type": "string",
            "format": "uri"
          },
          "expiresAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "pollIntervalSeconds": {
            "type": "integer",
            "format": "int32",
            "minimum": 1
          }
        },
        "additionalProperties": false
      },
      "SyncMutation": {
        "type": "object",
        "required": [
          "id",
          "kind",
          "baseVersion",
          "modifiedAtUtc",
          "isDeleted",
          "payload"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "kind": {
            "$ref": "#/components/schemas/SyncEntityKind"
          },
          "baseVersion": {
            "type": "integer",
            "format": "int64",
            "minimum": 0
          },
          "modifiedAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "isDeleted": {
            "type": "boolean"
          },
          "payload": {
            "type": "object",
            "additionalProperties": true
          }
        },
        "additionalProperties": false
      },
      "SyncPushRequest": {
        "type": "object",
        "required": [
          "deviceId",
          "mutations"
        ],
        "properties": {
          "deviceId": {
            "type": "string",
            "format": "uuid"
          },
          "mutations": {
            "type": "array",
            "maxItems": 500,
            "items": {
              "$ref": "#/components/schemas/SyncMutation"
            }
          }
        },
        "additionalProperties": false
      },
      "SyncPushResult": {
        "type": "object",
        "required": [
          "id",
          "version",
          "serverModifiedAtUtc",
          "accepted",
          "errorCode",

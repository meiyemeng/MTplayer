<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.Avalonia;assembly=LibVLCSharp.Avalonia"
        x:Class="MTPlayer.Mac.PlayerWindow"
        Title="MT播放器" Width="1280" Height="760" MinWidth="900" MinHeight="560"
        WindowStartupLocation="CenterScreen" Background="Black">
  <vlc:VideoView x:Name="VideoSurface">
    <Grid x:Name="Overlay" RowDefinitions="Auto,*,Auto" Background="Transparent">
      <Border Background="#B3090C10" Padding="24,18">
        <StackPanel Orientation="Horizontal" Spacing="14">
          <TextBlock x:Name="TitleText" Foreground="White" FontWeight="Bold" FontSize="22"/>
          <TextBlock x:Name="EpisodeText" Foreground="#C6CBD2" FontSize="16" VerticalAlignment="Center"/>
        </StackPanel>
      </Border>
      <Border Grid.Row="2" Background="#E6151920" CornerRadius="18" Margin="24" Padding="22">
        <StackPanel Spacing="13">
          <Grid ColumnDefinitions="58,*,58">
            <TextBlock x:Name="CurrentText" Text="00:00" Foreground="White" VerticalAlignment="Center"/>
            <Slider x:Name="Progress" Grid.Column="1" Minimum="0" Maximum="1" Margin="12,0"/>
            <TextBlock x:Name="DurationText" Grid.Column="2" Text="00:00" Foreground="White" HorizontalAlignment="Right" VerticalAlignment="Center"/>
          </Grid>
          <Grid ColumnDefinitions="Auto,Auto,Auto,Auto,*,Auto,150,110,Auto" ColumnSpacing="10">
            <Button x:Name="PreviousButton" Content="上一集"/>
            <Button x:Name="BackButton" Grid.Column="1" Content="↶ 10秒"/>
            <Button x:Name="PauseButton" Grid.Column="2" Content="暂停" Classes="primary"/>
            <Button x:Name="ForwardButton" Grid.Column="3" Content="10秒 ↷"/>
            <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
              <Button x:Name="IntroButton" Content="设片头"/>
              <Button x:Name="OutroButton" Content="设片尾"/>
              <Button x:Name="ClearSkipButton" Content="清除跳过"/>
              <TextBlock x:Name="SkipText" Foreground="#B7BEC8" VerticalAlignment="Center"/>
            </StackPanel>
            <Button x:Name="MuteButton" Grid.Column="5" Content="🔊"/>
            <Slider x:Name="Volume" Grid.Column="6" Minimum="0" Maximum="100" Value="80" VerticalAlignment="Center"/>
            <ComboBox x:Name="SpeedBox" Grid.Column="7"/>
            <Button x:Name="FullScreenButton" Grid.Column="8" Content="全屏"/>
          </Grid>
        </StackPanel>
      </Border>
    </Grid>
  </vlc:VideoView>
</Window>

<Window x:Class="WebHtv.Desktop.WebParserWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="影幕 · 解析播放" Width="1100" Height="720" Background="#0B1220"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
  <Grid>
    <wv2:WebView2 x:Name="Browser" />
    <Border x:Name="LoadingPanel" Background="#CC0B1220">
      <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
        <TextBlock Foreground="White" FontSize="22" Text="正在解析播放地址…" HorizontalAlignment="Center" />
        <TextBlock Margin="0,10,0,0" Foreground="#A9B8CC" Text="解析完成后将自动切换到原生播放器" />
      </StackPanel>
    </Border>
  </Grid>
</Window>

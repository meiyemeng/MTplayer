<Window x:Class="WebHtv.Desktop.PlayerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="MT播放器 · 播放" Width="1180" Height="760" MinWidth="850" MinHeight="560"
        Background="Black" FontFamily="Microsoft YaHei UI" WindowStartupLocation="CenterScreen"
        Closed="Window_Closed" Loaded="Window_Loaded" KeyDown="Window_KeyDown"
        MouseMove="Window_MouseMove" PreviewMouseDown="Window_PreviewMouseDown">
  <Window.Resources>
    <Style x:Key="PlayerButton" TargetType="Button">
      <Setter Property="Foreground" Value="#F7F7F8"/><Setter Property="Background" Value="#CC282B31"/>
      <Setter Property="BorderBrush" Value="#33FFFFFF"/><Setter Property="BorderThickness" Value="1"/>
      <Setter Property="Padding" Value="14,8"/><Setter Property="Margin" Value="4,0"/><Setter Property="Cursor" Value="Hand"/><Setter Property="FontSize" Value="13"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Chrome" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="17" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Chrome" Property="Background" Value="#E63A3E46"/><Setter TargetName="Chrome" Property="BorderBrush" Value="#66FFFFFF"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Background" Value="#FFE31D2B"/></Trigger><Trigger Property="IsEnabled" Value="False"><Setter TargetName="Chrome" Property="Opacity" Value="0.35"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>
    <Style x:Key="PrimaryPlayerButton" TargetType="Button" BasedOn="{StaticResource PlayerButton}"><Setter Property="Background" Value="#FFE31D2B"/><Setter Property="BorderBrush" Value="#FFE31D2B"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    <Style TargetType="ComboBoxItem"><Setter Property="Foreground" Value="#F5F5F6"/><Setter Property="Background" Value="#F21B1D22"/><Setter Property="Padding" Value="12,9"/><Style.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="#FF343840"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#FFE31D2B"/></Trigger></Style.Triggers></Style>
    <Style TargetType="ComboBox">
      <Setter Property="Foreground" Value="#F5F5F6"/><Setter Property="Background" Value="#E624272D"/><Setter Property="BorderBrush" Value="#35FFFFFF"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="12,7"/><Setter Property="Margin" Value="4,0"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBox"><Grid><ToggleButton x:Name="Toggle" Focusable="False" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Background="Transparent" BorderThickness="0"><ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border x:Name="Box" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderThickness="1" CornerRadius="16" Padding="12,7"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/></Grid.ColumnDefinitions><ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" VerticalAlignment="Center"/><Path Grid.Column="1" Data="M 2 4 L 7 9 L 12 4" Stroke="#C9CBD0" StrokeThickness="1.6" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Box" Property="Background" Value="#F0353941"/></Trigger></ControlTemplate.Triggers></ControlTemplate></ToggleButton.Template></ToggleButton><Popup x:Name="Popup" IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False"><Border Margin="0,7,0,0" Background="#F51A1C20" BorderBrush="#45FFFFFF" BorderThickness="1" CornerRadius="10" Padding="4"><ScrollViewer MaxHeight="320"><ItemsPresenter/></ScrollViewer></Border></Popup></Grid></ControlTemplate></Setter.Value></Setter>
    </Style>
    <Style TargetType="Slider">
      <Setter Property="Height" Value="30"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Slider"><Grid VerticalAlignment="Center" ClipToBounds="False"><Track x:Name="PART_Track" Height="5" Margin="10,0" VerticalAlignment="Center"><Track.DecreaseRepeatButton><RepeatButton Command="{x:Static Slider.DecreaseLarge}" Background="#FFE31D2B"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="{TemplateBinding Background}" CornerRadius="3"/></ControlTemplate></RepeatButton.Template></RepeatButton></Track.DecreaseRepeatButton><Track.IncreaseRepeatButton><RepeatButton Command="{x:Static Slider.IncreaseLarge}" Background="#59606A"><RepeatButton.Template><ControlTemplate TargetType="RepeatButton"><Border Background="{TemplateBinding Background}" CornerRadius="3"/></ControlTemplate></RepeatButton.Template></RepeatButton></Track.IncreaseRepeatButton><Track.Thumb><Thumb Width="18" Height="18"><Thumb.Template><ControlTemplate TargetType="Thumb"><Grid ClipToBounds="False"><Ellipse Fill="#F7F7F8" Stroke="#FFE31D2B" StrokeThickness="2"/><Ellipse Width="5" Height="5" Fill="#FFE31D2B"/></Grid></ControlTemplate></Thumb.Template></Thumb></Track.Thumb></Track></Grid></ControlTemplate></Setter.Value></Setter>
    </Style>
  </Window.Resources>
  <vlc:VideoView x:Name="VideoOutput">
    <Grid Background="Transparent">
      <Border x:Name="TopOverlay" VerticalAlignment="Top" Background="#9A08090B" Padding="24,17">
        <DockPanel><TextBlock x:Name="TitleText" Foreground="White" FontSize="20" FontWeight="SemiBold"/><TextBlock x:Name="EpisodeText" Foreground="#C7C9CE" FontSize="14" Margin="18,4,0,0"/></DockPanel>
      </Border>
      <Border x:Name="StatusOverlay" VerticalAlignment="Center" HorizontalAlignment="Center" Background="#EA16181D" BorderBrush="#35FFFFFF" BorderThickness="1" CornerRadius="16" Padding="24,15">
        <TextBlock x:Name="StatusText" Foreground="White" Text="正在连接播放线路…" FontSize="14"/>
      </Border>
      <Border x:Name="ControlOverlay" VerticalAlignment="Bottom" Margin="24" Background="#EC111317" BorderBrush="#38FFFFFF" BorderThickness="1" CornerRadius="18" Padding="18,14">
        <StackPanel>
          <Grid Margin="4,0,4,10"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="CurrentTimeText" Foreground="#E0E1E4" Text="00:00" VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Slider x:Name="PositionSlider" Grid.Column="1" Minimum="0" Maximum="1" PreviewMouseLeftButtonUp="PositionSlider_MouseUp" PreviewKeyUp="PositionSlider_KeyUp"/>
            <TextBlock x:Name="DurationText" Grid.Column="2" Foreground="#E0E1E4" Text="00:00" VerticalAlignment="Center" Margin="12,0,0,0"/>
          </Grid>
          <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,10">
            <ComboBox x:Name="SourceSelector" Width="150" SelectionChanged="SourceSelector_SelectionChanged" ToolTip="切换播放线路"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate></ComboBox>
            <ComboBox x:Name="EpisodeSelector" Width="130" SelectionChanged="EpisodeSelector_SelectionChanged" ToolTip="选择剧集"><ComboBox.ItemTemplate><DataTemplate><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate></ComboBox>
            <Button Style="{StaticResource PlayerButton}" Content="设片头" Click="SetIntro_Click" ToolTip="把当前进度设为该影片的片头结束点"/>
            <Button Style="{StaticResource PlayerButton}" Content="设片尾" Click="SetOutro_Click" ToolTip="把当前进度设为该影片的片尾开始点"/>
            <Button Style="{StaticResource PlayerButton}" Content="清除跳过" Click="ClearSkip_Click"/>
            <TextBlock x:Name="SkipMarkerText" Foreground="#AEB1B7" VerticalAlignment="Center" Margin="9,0,0,0"/>
          </WrapPanel>
          <DockPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <TextBlock Foreground="#D8D9DC" Text="音量" VerticalAlignment="Center" Margin="10,0,6,0"/>
              <Button x:Name="MuteButton" Style="{StaticResource PlayerButton}" Content="静音" Click="Mute_Click" ToolTip="一键静音/恢复声音"/>
              <Slider x:Name="VolumeSlider" Width="104" Minimum="0" Maximum="100" ValueChanged="VolumeSlider_ValueChanged" ToolTip="音量"/>
              <TextBlock Foreground="#D8D9DC" Text="倍速" VerticalAlignment="Center" Margin="10,0,2,0"/>
              <ComboBox x:Name="SpeedSelector" Width="88" SelectionChanged="SpeedSelector_SelectionChanged" ToolTip="播放倍速"><ComboBox.ItemTemplate><DataTemplate><TextBlock Foreground="#F5F5F6" Text="{Binding StringFormat={}{0:0.##}×}"/></DataTemplate></ComboBox.ItemTemplate></ComboBox>
              <Button x:Name="FullscreenButton" Style="{StaticResource PlayerButton}" Content="全屏" Click="Fullscreen_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal">
              <Button x:Name="PreviousButton" Style="{StaticResource PlayerButton}" Content="上一集" Click="Previous_Click"/>
              <Button Style="{StaticResource PlayerButton}" Content="↶ 10" Click="Back10_Click" ToolTip="后退 10 秒"/>
              <Button x:Name="PlayPauseButton" Style="{StaticResource PrimaryPlayerButton}" Content="暂停" Click="PlayPause_Click"/>
              <Button Style="{StaticResource PlayerButton}" Content="10 ↷" Click="Forward10_Click" ToolTip="前进 10 秒"/>
              <Button x:Name="NextButton" Style="{StaticResource PlayerButton}" Content="下一集" Click="Next_Click"/>
            </StackPanel>
          </DockPanel>
        </StackPanel>
      </Border>
    </Grid>
  </vlc:VideoView>
</Window>

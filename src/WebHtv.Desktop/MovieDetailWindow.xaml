<Window x:Class="WebHtv.Desktop.MovieDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MT播放器 · 影片详情" Width="1280" Height="850" MinWidth="1020" MinHeight="700"
        Background="#0B0D10" Foreground="White" FontFamily="Microsoft YaHei UI"
        WindowStartupLocation="CenterOwner" Loaded="Window_Loaded">
  <Window.Resources>
    <Style x:Key="DetailButton" TargetType="Button">
      <Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#292D33"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="18,11"/><Setter Property="Margin" Value="0,0,10,0"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Chrome" Property="Background" Value="#3A3F47"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Opacity" Value="0.75"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>
    <Style x:Key="PrimaryDetailButton" TargetType="Button" BasedOn="{StaticResource DetailButton}"><Setter Property="Background" Value="#E31D2B"/><Setter Property="FontWeight" Value="SemiBold"/></Style>
    <Style TargetType="ComboBoxItem"><Setter Property="Foreground" Value="#F5F5F6"/><Setter Property="Background" Value="#F21B1D22"/><Setter Property="Padding" Value="12,10"/><Style.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter Property="Background" Value="#FF343840"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter Property="Background" Value="#FFE31D2B"/></Trigger></Style.Triggers></Style>
    <Style TargetType="ComboBox">
      <Setter Property="Foreground" Value="#F5F5F6"/><Setter Property="Background" Value="#24272D"/><Setter Property="BorderBrush" Value="#41454D"/><Setter Property="Padding" Value="13,9"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBox"><Grid><ToggleButton Focusable="False" IsChecked="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Background="Transparent" BorderThickness="0"><ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border x:Name="Box" Background="{Binding Background, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderBrush="{Binding BorderBrush, RelativeSource={RelativeSource AncestorType=ComboBox}}" BorderThickness="1" CornerRadius="9" Padding="13,9"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="18"/></Grid.ColumnDefinitions><ContentPresenter Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}" ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}" VerticalAlignment="Center"/><Path Grid.Column="1" Data="M 2 4 L 7 9 L 12 4" Stroke="#C9CBD0" StrokeThickness="1.6" HorizontalAlignment="Center" VerticalAlignment="Center"/></Grid></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Box" Property="Background" Value="#343840"/></Trigger></ControlTemplate.Triggers></ControlTemplate></ToggleButton.Template></ToggleButton><Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" AllowsTransparency="True" Focusable="False"><Border Margin="0,7,0,0" Background="#F51A1C20" BorderBrush="#45FFFFFF" BorderThickness="1" CornerRadius="10" Padding="4"><ScrollViewer MaxHeight="330"><ItemsPresenter/></ScrollViewer></Border></Popup></Grid></ControlTemplate></Setter.Value></Setter>
    </Style>
    <Style TargetType="ListBoxItem">
      <Setter Property="Foreground" Value="#D7D9DD"/><Setter Property="Background" Value="#202329"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="Padding" Value="12,12"/><Setter Property="Margin" Value="0,0,9,9"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ListBoxItem"><Border x:Name="Episode" Background="{TemplateBinding Background}" CornerRadius="9" Padding="{TemplateBinding Padding}" BorderBrush="#30343B" BorderThickness="1"><ContentPresenter HorizontalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Episode" Property="Background" Value="#30343B"/><Setter TargetName="Episode" Property="BorderBrush" Value="#555B65"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="Episode" Property="Background" Value="#E31D2B"/><Setter TargetName="Episode" Property="BorderBrush" Value="#E31D2B"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>
  </Window.Resources>
  <Grid Margin="38,32,38,24">
    <Grid.RowDefinitions><RowDefinition Height="*"/><RowDefinition Height="Auto"/></Grid.RowDefinitions>
    <Grid>
      <Grid.ColumnDefinitions><ColumnDefinition Width="310"/><ColumnDefinition Width="34"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
      <Border Width="310" Height="460" VerticalAlignment="Top" CornerRadius="14" ClipToBounds="True" Background="#20242A"><Grid><Image Source="{Binding Card.CoverUrl}" Stretch="UniformToFill"/><Border VerticalAlignment="Bottom" Height="120"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#00101010"/><GradientStop Color="#F0101010" Offset="1"/></LinearGradientBrush></Border.Background></Border></Grid></Border>
      <Grid Grid.Column="2">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <StackPanel><TextBlock Text="{Binding Detail.Item.TypeName}" Foreground="#E31D2B" FontSize="13"/><TextBlock Text="{Binding Detail.Item.Title}" FontSize="38" FontWeight="Bold" Margin="0,7,0,9" TextWrapping="Wrap"/><TextBlock x:Name="MetadataText" Foreground="#9FA3AA" FontSize="14" Margin="0,0,0,14" TextWrapping="Wrap"/><TextBlock Text="{Binding Detail.Description}" Foreground="#C7C9CD" FontSize="14" LineHeight="23" MaxHeight="94" TextWrapping="Wrap"/><StackPanel Orientation="Horizontal" Margin="0,20,0,0"><Button x:Name="PlayButton" Style="{StaticResource PrimaryDetailButton}" Content="▶  播放所选集" Click="Play_Click"/><Button x:Name="FavoriteButton" Style="{StaticResource DetailButton}" Content="♡  加入收藏" Click="Favorite_Click"/></StackPanel></StackPanel>
        <Separator Grid.Row="1" Margin="0,22,0,18" Background="#31343A"/>
        <Grid Grid.Row="2" Margin="0,0,0,18"><Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="300"/><ColumnDefinition Width="28"/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="250"/></Grid.ColumnDefinitions><TextBlock VerticalAlignment="Center" Text="播放接口" FontWeight="SemiBold" Margin="0,0,14,0"/><ComboBox x:Name="InterfaceSelector" Grid.Column="1" SelectionChanged="InterfaceSelector_SelectionChanged"><ComboBox.ItemTemplate><DataTemplate><TextBlock Foreground="#F5F5F6" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/></DataTemplate></ComboBox.ItemTemplate></ComboBox><TextBlock Grid.Column="3" VerticalAlignment="Center" Text="播放线路" FontWeight="SemiBold" Margin="0,0,14,0"/><ComboBox x:Name="SourceSelector" Grid.Column="4" SelectionChanged="SourceSelector_SelectionChanged"><ComboBox.ItemTemplate><DataTemplate><TextBlock Foreground="#F5F5F6" Text="{Binding Name}" TextTrimming="CharacterEllipsis"/></DataTemplate></ComboBox.ItemTemplate></ComboBox></Grid>
        <Grid Grid.Row="3"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><DockPanel Margin="0,0,0,11"><TextBlock DockPanel.Dock="Right" Foreground="#7E838B" Text="双击剧集可直接播放"/><TextBlock Text="选择剧集" FontSize="17" FontWeight="SemiBold"/></DockPanel><ListBox x:Name="EpisodeList" Grid.Row="1" MinHeight="210" Background="#111318" BorderBrush="#272B31" BorderThickness="1" Padding="12" ScrollViewer.VerticalScrollBarVisibility="Auto" ScrollViewer.HorizontalScrollBarVisibility="Disabled" MouseDoubleClick="EpisodeList_MouseDoubleClick"><ListBox.ItemsPanel><ItemsPanelTemplate><WrapPanel ItemWidth="150" ItemHeight="54"/></ItemsPanelTemplate></ListBox.ItemsPanel></ListBox></Grid>
      </Grid>
    </Grid>
    <Border Grid.Row="1" Background="#15181C" CornerRadius="10" Padding="18,12" Margin="0,18,0,0"><TextBlock x:Name="StatusText" Foreground="#AEB2B9" Text="选择线路、播放接口与剧集后开始播放。"/></Border>
  </Grid>
</Window>

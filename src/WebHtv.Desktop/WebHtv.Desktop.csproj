<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <AssemblyName>MTPlayer</AssemblyName>
    <Product>MT播放器</Product>
    <Title>MT播放器</Title>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Version>1.3.1</Version>
    <InformationalVersion>1.3.1</InformationalVersion>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <AssemblyVersion>1.3.1.0</AssemblyVersion>
    <FileVersion>1.3.1.0</FileVersion>
    <UseWPF>true</UseWPF>
    <Platforms>x86;x64</Platforms>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <ApplicationIcon>Assets\mtplayer.ico</ApplicationIcon>
  </PropertyGroup>
  <ItemGroup>
    <Resource Include="Assets\logo-header.png" />
    <Resource Include="Assets\logo-header-transparent.png" />
    <Resource Include="Assets\mtplayer-icon.png" />
    <Resource Include="Assets\alipay-donate.png" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Microsoft.Web.WebView2" Version="1.0.4078.44" />
    <PackageReference Include="System.Security.Cryptography.ProtectedData" Version="8.0.0" />
    <ProjectReference Include="..\MTPlayer.Client.Core\MTPlayer.Client.Core.csproj" />
    <ProjectReference Include="..\WebHtv.Core\WebHtv.Core.csproj" />
    <ProjectReference Include="..\WebHtv.Configuration\WebHtv.Configuration.csproj" />
    <ProjectReference Include="..\WebHtv.Catalogue\WebHtv.Catalogue.csproj" />
    <ProjectReference Include="..\WebHtv.Spider\WebHtv.Spider.csproj" />
    <ProjectReference Include="..\WebHtv.Playback\WebHtv.Playback.csproj" />
  </ItemGroup>
</Project>

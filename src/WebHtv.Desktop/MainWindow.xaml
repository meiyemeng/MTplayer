<Window x:Class="WebHtv.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MT播放器" Width="1440" Height="900" MinWidth="1080" MinHeight="700"
        Background="#0B0D10" FontFamily="Microsoft YaHei UI" WindowStartupLocation="CenterScreen" Loaded="Window_Loaded">
  <Window.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    <SolidColorBrush x:Key="RedBrush" Color="#E31D2B"/><SolidColorBrush x:Key="MutedBrush" Color="#969AA1"/>
    <Style x:Key="NavButton" TargetType="Button">
      <Setter Property="Foreground" Value="#C7C9CD"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="22,15"/><Setter Property="Margin" Value="0,2"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="FontSize" Value="15"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Root" Background="{TemplateBinding Background}" BorderBrush="{StaticResource RedBrush}" BorderThickness="0" CornerRadius="0,10,10,0"><ContentPresenter Margin="{TemplateBinding Padding}"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Root" Property="Background" Value="#25282D"/><Setter Property="Foreground" Value="White"/></Trigger><Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="Root" Property="BorderThickness" Value="3,0,0,0"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>
    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#E31D2B"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="18,11"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="Chrome" Background="{TemplateBinding Background}" CornerRadius="10" Padding="{TemplateBinding Padding}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="Chrome" Property="Background" Value="#F02A37"/></Trigger><Trigger Property="IsPressed" Value="True"><Setter TargetName="Chrome" Property="Opacity" Value="0.76"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>
    <Style x:Key="QuietButton" TargetType="Button" BasedOn="{StaticResource ActionButton}"><Setter Property="Background" Value="#292C31"/><Setter Property="FontWeight" Value="Normal"/></Style>
    <Style x:Key="SectionCard" TargetType="Border"><Setter Property="Background" Value="#17191D"/><Setter Property="CornerRadius" Value="12"/><Setter Property="Padding" Value="22"/><Setter Property="Margin" Value="0,0,0,18"/><Setter Property="BorderBrush" Value="#24272C"/><Setter Property="BorderThickness" Value="1"/></Style>
    <Style TargetType="TextBox"><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="#202328"/><Setter Property="BorderBrush" Value="#34383F"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="13,10"/><Setter Property="CaretBrush" Value="White"/></Style>
    <Style x:Key="PosterButton" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/><Setter Property="BorderBrush" Value="Transparent"/><Setter Property="BorderThickness" Value="1"/><Setter Property="Padding" Value="0"/><Setter Property="Cursor" Value="Hand"/><Setter Property="HorizontalContentAlignment" Value="Stretch"/><Setter Property="VerticalContentAlignment" Value="Stretch"/><Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
      <Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="0"/></Setter.Value></Setter>
      <Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="FocusChrome" Background="Transparent" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="11"><ContentPresenter/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="-3"/></Setter.Value></Setter><Setter Property="Effect"><Setter.Value><DropShadowEffect BlurRadius="18" ShadowDepth="7" Opacity="0.48" Color="#000000"/></Setter.Value></Setter></Trigger><Trigger Property="IsPressed" Value="True"><Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="-1"/></Setter.Value></Setter></Trigger><Trigger Property="IsKeyboardFocused" Value="True"><Setter TargetName="FocusChrome" Property="BorderBrush" Value="#E31D2B"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter>
    </Style>
    <DataTemplate x:Key="PosterCardTemplate">
      <Button Style="{StaticResource PosterButton}" Width="{Binding DataContext.PosterWidth, RelativeSource={RelativeSource AncestorType=Window}}" Height="{Binding DataContext.PosterHeight, RelativeSource={RelativeSource AncestorType=Window}}" Margin="4,4,16,20" Tag="{Binding}" Click="Poster_Click" ToolTip="打开影片详情" AutomationProperties.Name="{Binding Title}">
        <Border CornerRadius="10" ClipToBounds="True" Background="#24272C"><Grid><Grid.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="{Binding AccentStart}"/><GradientStop Color="{Binding AccentEnd}" Offset="1"/></LinearGradientBrush></Grid.Background><Image Source="{Binding CoverUrl}" Stretch="UniformToFill"/><Border VerticalAlignment="Bottom" Height="112"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#00101010"/><GradientStop Color="#F0101010" Offset="1"/></LinearGradientBrush></Border.Background></Border><StackPanel VerticalAlignment="Bottom" Margin="13"><TextBlock Foreground="White" FontSize="17" FontWeight="SemiBold" Text="{Binding Title}" TextWrapping="Wrap"/><TextBlock Foreground="#C9CCD1" FontSize="11" Text="{Binding Caption}" Margin="0,4,0,0" TextWrapping="Wrap"/></StackPanel></Grid></Border>
      </Button>
    </DataTemplate>
    <DataTemplate x:Key="TopPosterTemplate">
      <Button Style="{StaticResource PosterButton}" Width="150" Height="222" Margin="4,4,14,8" Tag="{Binding}" Click="Poster_Click" ToolTip="打开影片详情" AutomationProperties.Name="{Binding Title}">
        <Border CornerRadius="10" ClipToBounds="True" Background="#202329"><Grid><Image Source="{Binding CoverUrl}" Stretch="UniformToFill"/><Border VerticalAlignment="Bottom" Height="88"><Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="0,1"><GradientStop Color="#00101010"/><GradientStop Color="#F20A0B0D" Offset="1"/></LinearGradientBrush></Border.Background></Border><StackPanel VerticalAlignment="Bottom" Margin="11"><TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextWrapping="Wrap" MaxHeight="42"/><TextBlock Text="{Binding Caption}" Foreground="#B9BDC3" FontSize="10" Margin="0,4,0,0"/></StackPanel></Grid></Border>
      </Button>
    </DataTemplate>
  </Window.Resources>
  <Grid>
    <Grid.ColumnDefinitions><ColumnDefinition Width="238"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
    <Border Background="#17191C" BorderBrush="#303237" BorderThickness="0,0,1,0">
      <DockPanel>
        <StackPanel DockPanel.Dock="Top" Margin="0,26,14,0">
          <Border Margin="22,0,8,26" Height="66" CornerRadius="8" ClipToBounds="True" Background="#17191C"><Image Source="Assets/logo-header-transparent.png" Stretch="Uniform"/></Border>
          <Button x:Name="HomeNav" Style="{StaticResource NavButton}" Tag="home" Content="⌂  首页" Click="Navigation_Click"/>
          <Button Style="{StaticResource NavButton}" Tag="search" Content="⌕  搜索" Click="Navigation_Click"/>
          <Button Style="{StaticResource NavButton}" Tag="favorites" Content="♡  我的收藏" Click="Navigation_Click"/>
          <Button Style="{StaticResource NavButton}" Tag="history" Content="◴  观看记录" Click="Navigation_Click"/>
          <Button Style="{StaticResource NavButton}" Tag="live" Content="●  直播频道" Click="Navigation_Click"/>
        </StackPanel>
        <StackPanel DockPanel.Dock="Bottom" Margin="0,0,14,20">
          <Separator Margin="20,0,6,12" Background="#33363B"/>
          <Button Style="{StaticResource NavButton}" Tag="settings" Content="⚙  设置" Click="Navigation_Click"/>
          <Button Style="{StaticResource NavButton}" Tag="about" Content="ⓘ  关于软件" Click="Navigation_Click"/>
          <TextBlock Margin="28,10" Foreground="#6F737A" FontSize="11" Text="本地数据 · 不预置内容"/>
        </StackPanel>
      </DockPanel>
    </Border>
    <Grid Grid.Column="1">
      <Grid x:Name="HomePage">
        <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions>
        <DockPanel Margin="38,24,38,18"><DockPanel DockPanel.Dock="Right" Width="430"><Button DockPanel.Dock="Right" Margin="10,0,0,0" Style="{StaticResource ActionButton}" Content="搜索" Click="Search_Click"/><TextBox x:Name="SearchBox" FontSize="14" Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"/></DockPanel><StackPanel><TextBlock Foreground="#E31D2B" FontSize="12" Text="MT 精选"/><TextBlock Foreground="White" FontSize="25" FontWeight="SemiBold" Text="热门片单"/></StackPanel></DockPanel>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><StackPanel Margin="38,0,38,40">
          <StackPanel Visibility="{Binding ShowTopLists, Converter={StaticResource BooleanToVisibilityConverter}}">
          <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="电影 Top 10" Margin="0,0,0,12"/><ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,26"><ItemsControl ItemsSource="{Binding TopMovies}" ItemTemplate="{StaticResource TopPosterTemplate}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl></ScrollViewer>
          <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="电视剧 Top 10" Margin="0,0,0,12"/><ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,26"><ItemsControl ItemsSource="{Binding TopSeries}" ItemTemplate="{StaticResource TopPosterTemplate}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl></ScrollViewer>
          <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="动漫电影 Top 10" Margin="0,0,0,12"/><ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,26"><ItemsControl ItemsSource="{Binding TopAnime}" ItemTemplate="{StaticResource TopPosterTemplate}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl></ScrollViewer>
          <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="动漫番剧 Top 10" Margin="0,0,0,12"/><ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,26"><ItemsControl ItemsSource="{Binding TopAnimeSeries}" ItemTemplate="{StaticResource TopPosterTemplate}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl></ScrollViewer>
          <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="综艺 Top 10" Margin="0,0,0,12"/><ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,30"><ItemsControl ItemsSource="{Binding TopVariety}" ItemTemplate="{StaticResource TopPosterTemplate}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><StackPanel Orientation="Horizontal"/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl></ScrollViewer>
          </StackPanel>
          <DockPanel Margin="0,0,0,14"><Button DockPanel.Dock="Right" Style="{StaticResource QuietButton}" Content="调整密度" Click="PosterSettings_Click"/><TextBlock Foreground="White" FontSize="23" FontWeight="SemiBold" Text="搜索结果"/></DockPanel>
          <Border Visibility="{Binding IsPosterSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource SectionCard}"><StackPanel Orientation="Horizontal"><TextBlock Foreground="White" VerticalAlignment="Center" Text="封面密度" Margin="0,0,20,0"/><Button Style="{StaticResource QuietButton}" Content="紧凑" Click="CompactPosterWall_Click" Margin="0,0,8,0"/><Button Style="{StaticResource QuietButton}" Content="标准" Click="StandardPosterWall_Click" Margin="0,0,8,0"/><Button Style="{StaticResource QuietButton}" Content="舒展" Click="ComfortablePosterWall_Click"/></StackPanel></Border>
          <ItemsControl ItemsSource="{Binding PosterWall}" ItemTemplate="{StaticResource PosterCardTemplate}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl>
          <TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
        </StackPanel></ScrollViewer>
      </Grid>
      <Grid x:Name="LibraryPage" Visibility="Collapsed"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Margin="38,28,38,20"><TextBlock x:Name="LibraryTitle" Foreground="White" FontSize="28" FontWeight="Bold"/><TextBlock x:Name="LibrarySubtitle" Foreground="{StaticResource MutedBrush}" Margin="0,7,0,0"/></StackPanel><ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><StackPanel Margin="38,0,38,38"><ItemsControl ItemsSource="{Binding LibraryCards}" ItemTemplate="{StaticResource PosterCardTemplate}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel></ItemsControl><TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding StatusMessage}"/></StackPanel></ScrollViewer></Grid>
      <Grid x:Name="LivePage" Visibility="Collapsed"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Margin="38,28,38,20"><TextBlock Foreground="White" FontSize="28" FontWeight="Bold" Text="直播频道"/><TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,7,0,0" Text="支持 M3U、M3U8、TXT 台标及 XMLTV 节目预告。"/></StackPanel><ListBox Grid.Row="1" Margin="38,0,38,38" ItemsSource="{Binding LiveChannels}" Background="Transparent" BorderThickness="0" ScrollViewer.VerticalScrollBarVisibility="Auto"><ListBox.ItemTemplate><DataTemplate><Button Width="860" Margin="0,0,0,8" Padding="14,10" HorizontalContentAlignment="Stretch" Background="#191C20" BorderThickness="0" Tag="{Binding}" Click="LiveChannel_Click"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="48"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><Border Width="38" Height="38" CornerRadius="7" Background="#292D33"><Image Source="{Binding LogoUrl}" Stretch="Uniform"/></Border><StackPanel Grid.Column="1" Margin="12,0"><TextBlock Foreground="White" FontSize="15" Text="{Binding Name}"/><StackPanel Orientation="Horizontal" Margin="0,3,0,0"><TextBlock Foreground="#8F949C" FontSize="11" Text="{Binding NowPlaying, StringFormat=正在播：{0}}"/><TextBlock Foreground="#686D75" FontSize="11" Text="{Binding NextPlaying, StringFormat=  ·  接下来：{0}}"/></StackPanel></StackPanel><TextBlock Grid.Column="2" Foreground="#777B82" Text="{Binding Group}" VerticalAlignment="Center"/></Grid></Button></DataTemplate></ListBox.ItemTemplate></ListBox></Grid>
      <Grid x:Name="SettingsPage" Visibility="Collapsed"><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/></Grid.RowDefinitions><StackPanel Margin="38,28,38,18"><TextBlock Foreground="White" FontSize="28" FontWeight="Bold" Text="设置"/><TextBlock Foreground="{StaticResource MutedBrush}" Margin="0,7,0,0" Text="配置源、播放行为、封面与本地数据统一在这里管理。"/></StackPanel><ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"><StackPanel Margin="38,0,38,40">
        <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="配置源管理" Margin="0,0,0,12"/><Border Style="{StaticResource SectionCard}"><StackPanel><TextBlock Foreground="White" FontWeight="SemiBold" Text="添加配置源"/><Grid Margin="0,12,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="ConfigurationSourceNameText" ToolTip="配置源名称"/><TextBox x:Name="ConfigurationSourceAddressText" Grid.Column="1" Margin="10,0" Text="{Binding ConfigurationAddress, Mode=OneWay}" ToolTip="TVBox 单仓或多仓地址"/><Button Grid.Column="2" Style="{StaticResource ActionButton}" Content="添加并启用" Click="AddConfigurationSource_Click"/></Grid><ItemsControl ItemsSource="{Binding ConfigurationSources}" Margin="0,14,0,0"><ItemsControl.ItemTemplate><DataTemplate><Border Background="#202329" CornerRadius="9" Padding="12" Margin="0,0,0,8"><DockPanel><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><Button Style="{StaticResource QuietButton}" Content="启用" Tag="{Binding}" Click="ActivateConfigurationSource_Click" Margin="0,0,8,0"/><Button Style="{StaticResource QuietButton}" Content="删除" Tag="{Binding}" Click="RemoveConfigurationSource_Click"/></StackPanel><StackPanel><TextBlock Foreground="White" FontWeight="SemiBold" Text="{Binding Name}"/><TextBlock Foreground="#89909A" FontSize="11" Text="{Binding Address}" Margin="0,4,12,0" TextTrimming="CharacterEllipsis"/></StackPanel></DockPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl><TextBlock Foreground="#858990" Margin="0,6,0,0" Text="可保存多个配置源；点击“启用”切换当前配置。"/></StackPanel></Border>
        <Border Style="{StaticResource SectionCard}"><StackPanel><TextBlock Foreground="White" FontWeight="SemiBold" Text="片源开关"/><ScrollViewer Height="220" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto"><ItemsControl ItemsSource="{Binding SiteOptions}"><ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate></ItemsControl.ItemsPanel><ItemsControl.ItemTemplate><DataTemplate><CheckBox Width="260" Margin="0,0,12,10" Foreground="#D7D9DD" Content="{Binding Name}" IsChecked="{Binding IsEnabled, Mode=TwoWay}"/></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></ScrollViewer></StackPanel></Border>
        <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="自定义直播源" Margin="0,8,0,12"/><Border Style="{StaticResource SectionCard}"><StackPanel><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="180"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions><TextBox x:Name="LiveSourceNameText" ToolTip="直播源名称"/><TextBox x:Name="LiveSourceAddressText" Grid.Column="1" Margin="10,0" ToolTip="M3U / M3U8 / TXT 地址"/><TextBox x:Name="LiveEpgAddressText" Grid.Column="2" Margin="0,0,10,0" ToolTip="EPG 地址（可选，支持台标与节目预告）"/><Button Grid.Column="3" Style="{StaticResource ActionButton}" Content="添加直播源" Click="AddLiveSource_Click"/></Grid><TextBlock Foreground="#858990" Margin="0,9,0,10" Text="频道会读取 tvg-logo 台标；可选 EPG 地址用于节目预告匹配。"/><ItemsControl ItemsSource="{Binding CustomLiveSources}"><ItemsControl.ItemTemplate><DataTemplate><Border Background="#202329" CornerRadius="8" Padding="11" Margin="0,0,0,7"><DockPanel><Button DockPanel.Dock="Right" Style="{StaticResource QuietButton}" Content="删除" Tag="{Binding}" Click="RemoveLiveSource_Click"/><StackPanel><TextBlock Foreground="White" Text="{Binding Name}"/><TextBlock Foreground="#858990" FontSize="11" Text="{Binding Address}"/></StackPanel></DockPanel></Border></DataTemplate></ItemsControl.ItemTemplate></ItemsControl></StackPanel></Border>
        <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="播放器设置" Margin="0,8,0,12"/><Border Style="{StaticResource SectionCard}"><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="220"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions><Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/></Grid.RowDefinitions><TextBlock Foreground="White" Text="硬件解码" Margin="0,10"/><CheckBox x:Name="HardwareDecodeCheck" Grid.Column="1" Foreground="#D7D9DD" Content="启用（推荐）" Margin="0,10"/><TextBlock Grid.Row="1" Foreground="White" Text="默认播放倍速" Margin="0,10"/><ComboBox x:Name="DefaultSpeedCombo" Grid.Row="1" Grid.Column="1" Width="160" HorizontalAlignment="Left"/><TextBlock Grid.Row="2" Foreground="White" Text="默认音量" Margin="0,10"/><Slider x:Name="DefaultVolumeSlider" Grid.Row="2" Grid.Column="1" Width="320" HorizontalAlignment="Left" Minimum="0" Maximum="100"/><TextBlock Grid.Row="3" Foreground="White" Text="窗口行为" Margin="0,10"/><CheckBox x:Name="AutoFullscreenCheck" Grid.Row="3" Grid.Column="1" Foreground="#D7D9DD" Content="打开播放器时自动全屏" Margin="0,10"/></Grid></Border>
        <TextBlock Foreground="White" FontSize="22" FontWeight="SemiBold" Text="封面与数据" Margin="0,8,0,12"/><Border Style="{StaticResource SectionCard}"><StackPanel><CheckBox x:Name="UseSourceCoversCheck" Foreground="#D7D9DD" Content="使用片源封面；缺失时显示标题渐变海报"/><TextBlock Foreground="#969AA1" Margin="0,16,0,6" Text="TMDB API Key（可选）"/><TextBox x:Name="TmdbKeyText"/><StackPanel Orientation="Horizontal" Margin="0,16,0,0"><Button Style="{StaticResource QuietButton}" Content="清空观看记录" Click="ClearHistory_Click" Margin="0,0,10,0"/><Button Style="{StaticResource ActionButton}" Content="保存全部设置" Click="SaveSettings_Click"/></StackPanel></StackPanel></Border><TextBlock Foreground="{StaticResource MutedBrush}" Text="{Binding StatusMessage}" TextWrapping="Wrap"/>
      </StackPanel></ScrollViewer></Grid>
      <Grid x:Name="AboutPage" Visibility="Collapsed"><ScrollViewer VerticalScrollBarVisibility="Auto"><StackPanel Margin="52,46" MaxWidth="900" HorizontalAlignment="Left"><TextBlock Foreground="#E31D2B" Text="ABOUT MT" FontSize="12"/><TextBlock Foreground="White" FontSize="34" FontWeight="Bold" Text="关于 MT播放器" Margin="0,8,0,8"/><TextBlock Foreground="#AEB2B9" Text="Windows 10 / 11 原生影视播放器" FontSize="15"/><Border Style="{StaticResource SectionCard}" Margin="0,34,0,18"><StackPanel><TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="版权与内容说明"/><TextBlock Foreground="#C4C7CC" Margin="0,14,0,0" LineHeight="25" TextWrapping="Wrap" Text="MT播放器是本地播放、检索与配置管理工具，不预置、不存储、不上传、不分发任何影视内容。节目资料、播放链接与直播地址均来自用户自行导入的第三方配置，其版权归相应权利人所有。请仅在获得授权并符合所在地法律法规的前提下使用。"/></StackPanel></Border><Border Style="{StaticResource SectionCard}"><StackPanel><TextBlock Foreground="White" FontSize="20" FontWeight="SemiBold" Text="开源组件"/><TextBlock Foreground="#C4C7CC" Margin="0,14,0,0" LineHeight="25" TextWrapping="Wrap" Text="播放器使用 .NET、WPF、LibVLCSharp、Jint 等开源组件。各组件遵循其原有许可证；发布源代码时请一并保留项目中的许可证与第三方声明。"/></StackPanel></Border><TextBlock Foreground="#777B82" Margin="0,18,0,0" Text="Copyright © 2026 MT播放器. All rights reserved."/></StackPanel></ScrollViewer></Grid>
    </Grid>
  </Grid>
</Window>

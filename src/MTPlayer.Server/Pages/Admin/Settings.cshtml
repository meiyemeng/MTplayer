@page "/admin/settings"
@model MTPlayer.Server.Pages.Admin.SettingsModel
@{
    Layout = "/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "系统设置";
    ViewData["Description"] = "配置公开地址、邮件服务与账号策略";
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="notice" role="status">@Model.StatusMessage</div>
}

<form method="post">
    <div asp-validation-summary="ModelOnly"></div>

    <div class="settings-grid">
        <section class="panel span-7" aria-labelledby="public-url-title">
            <header class="panel-header">
                <span class="panel-index">01</span>
                <div class="panel-heading">
                    <h2 id="public-url-title">公网访问地址</h2>
                    <p>客户端、验证邮件和密码找回使用的 HTTPS 域名。</p>
                </div>
                <span class="badge @(Model.PublicBaseUrlConfigured ? "good" : "warn")">
                    @(Model.PublicBaseUrlConfigured ? "已配置" : "等待配置")
                </span>
            </header>
            <div class="panel-body">
                <div class="form-grid">
                    <div class="field">
                        <label asp-for="Input.PublicBaseUrl">公开 HTTPS 地址</label>
                        <input asp-for="Input.PublicBaseUrl" type="url" placeholder="https://api.example.com" autocomplete="off" />
                        <span class="field-hint">只填写最终公开域名，不填写群晖内网地址或端口。</span>
                        <span asp-validation-for="Input.PublicBaseUrl"></span>
                    </div>
                    <div class="field">
                        <label class="check-row">
                            <input asp-for="Input.ClearPublicBaseUrl" />
                            <span class="checkbox-ui" aria-hidden="true"></span>
                            <span class="check-copy">
                                <strong>清除当前公开地址</strong>
                                <small>保存后将暂停邮件验证链接与客户端自动发现。</small>
                            </span>
                        </label>
                    </div>
                </div>
            </div>
        </section>

        <section class="panel span-5" aria-labelledby="account-policy-title">
            <header class="panel-header">
                <span class="panel-index">02</span>
                <div class="panel-heading">
                    <h2 id="account-policy-title">账号策略</h2>
                    <p>控制新用户进入和账号恢复方式。</p>
                </div>
            </header>
            <div class="panel-body">
                <div class="switch-list">
                    <label class="switch-row">
                        <input asp-for="Input.RegistrationEnabled" />
                        <span class="switch-copy"><strong>开放用户注册</strong><small>允许客户端创建新账号</small></span>
                        <span class="switch-ui" aria-hidden="true"></span>
                    </label>
                    <label class="switch-row">
                        <input asp-for="Input.RequireVerifiedEmail" />
                        <span class="switch-copy"><strong>登录前验证邮箱</strong><small>减少无效账号与邮箱冒用</small></span>
                        <span class="switch-ui" aria-hidden="true"></span>
                    </label>
                    <label class="switch-row">
                        <input asp-for="Input.PasswordResetEnabled" />
                        <span class="switch-copy"><strong>允许找回密码</strong><small>通过验证邮件重设密码</small></span>
                        <span class="switch-ui" aria-hidden="true"></span>
                    </label>
                </div>
            </div>
        </section>

        <section class="panel span-12" aria-labelledby="smtp-title">
            <header class="panel-header">
                <span class="panel-index">03</span>
                <div class="panel-heading">
                    <h2 id="smtp-title">邮件发送服务</h2>
                    <p>用于邮箱验证、密码找回和系统测试邮件。</p>
                </div>
                <span class="badge @(Model.MailConfigurationComplete ? "good" : "warn")">
                    @(Model.MailConfigurationComplete ? "可以发信" : "配置未完成")
                </span>
            </header>
            <div class="panel-body">
                <div class="form-grid">
                    <div class="field two-thirds">
                        <label asp-for="Input.SmtpHost">SMTP 服务器</label>
                        <input asp-for="Input.SmtpHost" placeholder="smtp.example.com" autocomplete="off" />
                        <span asp-validation-for="Input.SmtpHost"></span>
                    </div>
                    <div class="field third">
                        <label asp-for="Input.SmtpPort">端口</label>
                        <input asp-for="Input.SmtpPort" inputmode="numeric" />
                        <span asp-validation-for="Input.SmtpPort"></span>
                    </div>
                    <div class="field half">
                        <label asp-for="Input.SmtpUsername">SMTP 用户名</label>
                        <input asp-for="Input.SmtpUsername" autocomplete="username" placeholder="通常为完整邮箱地址" />
                        <span asp-validation-for="Input.SmtpUsername"></span>
                    </div>
                    <div class="field half">
                        <label asp-for="Input.NewSmtpPassword">SMTP 密码</label>
                        <div class="password-wrap">
                            <input asp-for="Input.NewSmtpPassword" type="password" autocomplete="new-password" placeholder="@(Model.SmtpPasswordConfigured ? "已保存；留空则保持不变" : "填写邮箱授权码或密码")" />
                            <button class="password-toggle" type="button" data-password-toggle="Input_NewSmtpPassword" aria-label="显示密码">显示</button>
                        </div>
                        <span asp-validation-for="Input.NewSmtpPassword"></span>
                    </div>
                    <div class="field half">
                        <label asp-for="Input.SmtpFromName">发件人名称</label>
                        <input asp-for="Input.SmtpFromName" placeholder="MT播放器" />
                        <span asp-validation-for="Input.SmtpFromName"></span>
                    </div>
                    <div class="field half">
                        <label asp-for="Input.SmtpFromAddress">发件邮箱</label>
                        <input asp-for="Input.SmtpFromAddress" type="email" placeholder="noreply@example.com" />
                        <span asp-validation-for="Input.SmtpFromAddress"></span>
                    </div>
                    <div class="field half">
                        <label class="check-row">
                            <input asp-for="Input.SmtpUseTls" />
                            <span class="checkbox-ui" aria-hidden="true"></span>
                            <span class="check-copy"><strong>启用 TLS/SSL</strong><small>推荐开启，保护邮件账号凭据。</small></span>
                        </label>
                    </div>
                    <div class="field half">
                        <label class="check-row">
                            <input asp-for="Input.ClearSmtpPassword" />
                            <span class="checkbox-ui" aria-hidden="true"></span>
                            <span class="check-copy"><strong>清除已保存的 SMTP 密码</strong><small>保存后邮件发送将暂停。</small></span>
                        </label>
                    </div>
                </div>
            </div>
        </section>

        <section class="panel span-5" aria-labelledby="expiry-title">
            <header class="panel-header">
                <span class="panel-index">04</span>
                <div class="panel-heading">
                    <h2 id="expiry-title">链接有效时间</h2>
                    <p>过期链接会自动失效，用户需要重新申请。</p>
                </div>
            </header>
            <div class="panel-body">
                <div class="form-grid">
                    <div class="field half">
                        <label asp-for="Input.EmailVerificationTokenExpiryMinutes">验证邮件</label>
                        <input asp-for="Input.EmailVerificationTokenExpiryMinutes" inputmode="numeric" />
                        <span class="field-hint">分钟</span>
                        <span asp-validation-for="Input.EmailVerificationTokenExpiryMinutes"></span>
                    </div>
                    <div class="field half">
                        <label asp-for="Input.PasswordResetTokenExpiryMinutes">重置密码</label>
                        <input asp-for="Input.PasswordResetTokenExpiryMinutes" inputmode="numeric" />
                        <span class="field-hint">分钟</span>
                        <span asp-validation-for="Input.PasswordResetTokenExpiryMinutes"></span>
                    </div>
                </div>
            </div>
        </section>

        <section class="panel span-7" aria-labelledby="template-title">
            <header class="panel-header">
                <span class="panel-index">05</span>
                <div class="panel-heading">
                    <h2 id="template-title">邮件内容</h2>
                    <p>展开需要修改的模板；其余内容保持收起。</p>
                </div>
            </header>
            <div class="panel-body">
                <div class="template-stack">
                    <details class="template-card" open>
                        <summary><strong>邮箱验证</strong><span>新用户确认邮箱</span></summary>
                        <div class="template-card-content">
                            <div class="form-grid">
                                <div class="field">
                                    <label asp-for="Input.VerificationSubjectTemplate">邮件标题</label>
                                    <input asp-for="Input.VerificationSubjectTemplate" />
                                    <span asp-validation-for="Input.VerificationSubjectTemplate"></span>
                                </div>
                                <div class="field">
                                    <label asp-for="Input.VerificationBodyTemplate">HTML 正文</label>
                                    <textarea asp-for="Input.VerificationBodyTemplate"></textarea>
                                    <span asp-validation-for="Input.VerificationBodyTemplate"></span>
                                    <div class="token-list"><code>{email}</code><code>{verificationUrl}</code><code>{expiresMinutes}</code></div>
                                </div>
                            </div>
                        </div>
                    </details>

                    <details class="template-card">
                        <summary><strong>重置密码</strong><span>找回账号密码</span></summary>
                        <div class="template-card-content">
                            <div class="form-grid">
                                <div class="field">
                                    <label asp-for="Input.ResetSubjectTemplate">邮件标题</label>
                                    <input asp-for="Input.ResetSubjectTemplate" />
                                    <span asp-validation-for="Input.ResetSubjectTemplate"></span>
                                </div>
                                <div class="field">
                                    <label asp-for="Input.ResetBodyTemplate">HTML 正文</label>
                                    <textarea asp-for="Input.ResetBodyTemplate"></textarea>
                                    <span asp-validation-for="Input.ResetBodyTemplate"></span>
                                    <div class="token-list"><code>{email}</code><code>{resetUrl}</code><code>{expiresMinutes}</code></div>
                                </div>
                            </div>
                        </div>
                    </details>

                    <details class="template-card">
                        <summary><strong>测试邮件</strong><span>检查 SMTP 是否可用</span></summary>
                        <div class="template-card-content">
                            <div class="form-grid">
                                <div class="field">
                                    <label asp-for="Input.TestSubjectTemplate">邮件标题</label>
                                    <input asp-for="Input.TestSubjectTemplate" />
                                    <span asp-validation-for="Input.TestSubjectTemplate"></span>
                                </div>
                                <div class="field">
                                    <label asp-for="Input.TestBodyTemplate">HTML 正文</label>
                                    <textarea asp-for="Input.TestBodyTemplate"></textarea>
                                    <span asp-validation-for="Input.TestBodyTemplate"></span>
                                    <div class="token-list"><code>{email}</code></div>
                                </div>
                            </div>
                        </div>
                    </details>
                </div>
            </div>
        </section>
    </div>

    <div class="action-bar">
        <button class="button primary" type="submit">保存全部设置</button>
        <span class="field-hint">敏感信息会加密保存；留空不会覆盖已保存的密码。</span>
    </div>
</form>

<section class="panel span-12" aria-labelledby="test-mail-title" style="margin-top: 24px">
    <header class="panel-header">
        <span class="panel-index">TEST</span>
        <div class="panel-heading">
            <h2 id="test-mail-title">发送测试邮件</h2>
            <p>保存 SMTP 设置后，用真实邮箱检查投递情况。</p>
        </div>
    </header>
    <div class="panel-body">
        <form class="test-mail-row" method="post" asp-page-handler="TestEmail">
            <div class="field">
                <label asp-for="TestRecipientEmail">收件邮箱</label>
                <input asp-for="TestRecipientEmail" type="email" placeholder="you@example.com" />
                <span asp-validation-for="TestRecipientEmail"></span>
            </div>
            @if (Model.MailConfigurationComplete)
            {
                <button class="button" type="submit">发送测试邮件</button>
            }
            else
            {
                <button class="button" type="submit" disabled>发送测试邮件</button>
                <span class="test-mail-message">先保存完整的公开地址和 SMTP 设置，测试按钮才会启用。</span>
            }
        </form>
    </div>
</section>

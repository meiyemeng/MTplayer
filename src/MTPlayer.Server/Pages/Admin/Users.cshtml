@page "/admin/users"
@model MTPlayer.Server.Pages.Admin.UsersModel
@{
    Layout = "/Pages/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "用户管理";
    ViewData["Description"] = "查看登录位置、会员状态、设备及用户配置的影视与直播接口";
    var enabledUsers = Model.Users.Count(user => !user.Disabled);
    var activeDevices = Model.Users.Sum(user => user.ActiveDeviceCount);
}

@if (!string.IsNullOrEmpty(Model.StatusMessage))
{
    <div class="notice" role="status">@Model.StatusMessage</div>
}

<section class="metric-strip" aria-label="用户概况">
    <div class="metric"><strong>@Model.Users.Count</strong><span>全部账号</span></div>
    <div class="metric"><strong>@enabledUsers</strong><span>正常使用</span></div>
    <div class="metric"><strong>@activeDevices</strong><span>活跃设备</span></div>
</section>

<section class="table-panel" aria-labelledby="user-list-title">
    <header class="table-toolbar">
        <div>
            <h2 id="user-list-title">账号列表</h2>
            <p>禁用账号会立即撤销其全部设备会话。</p>
        </div>
        <span class="badge good">实时数据</span>
    </header>

    @if (Model.Users.Count == 0)
    {
        <div class="empty-state">还没有用户。开放注册后，新账号会显示在这里。</div>
    }
    else
    {
        <div class="table-scroll">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>用户</th>
                        <th>角色</th>
                        <th>邮箱验证</th>
                        <th>账号状态</th>
                        <th>设备</th>
                        <th>登录位置</th>
                        <th>会员</th>
                        <th>用户来源</th>
                        <th>操作</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var user in Model.Users)
                {
                    <tr>
                        <td>
                            <div class="user-cell">
                                <span class="user-avatar" aria-hidden="true">@user.Email[..1]</span>
                                <span class="user-email">@user.Email</span>
                            </div>
                        </td>
                        <td><span class="role-label">@(user.Role == "admin" ? "管理员" : "用户")</span></td>
                        <td>
                            <span class="state-pill @(user.EmailVerified ? string.Empty : "pending")">
                                @(user.EmailVerified ? "已验证" : "待验证")
                            </span>
                        </td>
                        <td>
                            <span class="state-pill @(user.Disabled ? "disabled" : string.Empty)">
                                @(user.Disabled ? "已禁用" : "正常")
                            </span>
                        </td>
                        <td>@user.ActiveDeviceCount 台</td>
                        <td>
                            <strong>@(user.LastLoginCity ?? "未知城市")</strong><br />
                            <small>@(user.LastLoginIp ?? "未记录 IP")</small><br />
                            <small>@(user.LastLoginAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "尚未登录")</small>
                        </td>
                        <td>
                            <form class="membership-form" method="post" asp-page-handler="Membership">
                                <input type="hidden" name="userId" value="@user.Id" />
                                <select name="membershipLevel" aria-label="会员等级">
                                    <option value="free" selected="@(user.MembershipLevel == "free" ? "selected" : null)">普通用户</option>
                                    <option value="member" selected="@(user.MembershipLevel == "member" ? "selected" : null)">会员</option>
                                    <option value="vip" selected="@(user.MembershipLevel == "vip" ? "selected" : null)">VIP</option>
                                </select>
                                <input type="datetime-local" name="membershipExpiresAtUtc" value="@(user.MembershipExpiresAtUtc?.ToString("yyyy-MM-ddTHH:mm"))" aria-label="会员到期时间" />
                                <button class="button small ghost" type="submit">保存</button>
                            </form>
                        </td>
                        <td>
                            <details class="source-details">
                                <summary>@user.ConfigurationSourceAddresses.Count 配置 / @user.VideoInterfaceAddresses.Count 影视 / @user.LiveSourceAddresses.Count 直播</summary>
                                <strong>配置源</strong>
                                @foreach (var address in user.ConfigurationSourceAddresses) { <code>@address</code> }
                                <strong>影视接口</strong>
                                @foreach (var address in user.VideoInterfaceAddresses) { <code>@address</code> }
                                <strong>直播接口</strong>
                                @foreach (var address in user.LiveSourceAddresses) { <code>@address</code> }
                            </details>
                        </td>
                        <td>
                            <form class="row-actions" method="post">
                                <input type="hidden" name="userId" value="@user.Id" />
                                @if (user.Disabled)
                                {
                                    <button class="button small" asp-page-handler="Enable" type="submit">启用账号</button>
                                }
                                else
                                {
                                    <button class="button small danger" asp-page-handler="Disable" type="submit" data-confirm="确定禁用此账号并撤销全部设备会话吗？">禁用</button>
                                }
                                <button class="button small ghost" asp-page-handler="RevokeAll" type="submit" data-confirm="确定让该用户的所有设备退出登录吗？">退出全部设备</button>
                            </form>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</section>
